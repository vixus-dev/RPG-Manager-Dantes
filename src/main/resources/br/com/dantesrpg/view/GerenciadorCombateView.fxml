<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.dantesrpg.controller.GerenciadorCombateController">

   <!-- ========== BARRA SUPERIOR: Efeito de Andar + Contador ========== -->
   <top>
      <VBox spacing="0">
         <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #0b0914; -fx-padding: 10 15; -fx-border-color: rgba(233, 69, 96, 0.2); -fx-border-width: 0 0 2 0;">
            <children>
               <Label style="-fx-font-weight: bold; -fx-text-fill: #e94560; -fx-font-size: 13px;" text="EFEITO DE ANDAR:" />
               <ComboBox fx:id="comboEfeitoAndar" prefWidth="260.0" promptText="Selecione o Andar..." style="-fx-font-size: 12px;"/>
               <CheckBox fx:id="checkEfeitoAndarAtivo" text="ATIVO" style="-fx-text-fill: #00ff88; -fx-font-weight: bold;" />
               <Separator orientation="VERTICAL" style="-fx-padding: 0 5;" />
               <!-- Contador do Efeito de Andar -->
               <Label fx:id="lblContadorAndar" style="-fx-font-weight: bold; -fx-text-fill: #ff6b6b; -fx-font-size: 14px; -fx-padding: 4 12; -fx-background-color: rgba(255,50,50,0.15); -fx-background-radius: 5; -fx-border-color: #ff6b6b; -fx-border-radius: 5; -fx-border-width: 1;" text="" managed="false" visible="false"/>
               <Region HBox.hgrow="ALWAYS" />
               <Button onAction="#onRefreshClick" style="-fx-background-color: rgba(0, 240, 255, 0.1); -fx-text-fill: #00f0ff; -fx-font-size: 11px; -fx-background-radius: 5; -fx-border-color: rgba(0, 240, 255, 0.25); -fx-border-width: 1; -fx-cursor: hand;" text="Atualizar" />
               <Button onAction="#onCurarTodosClick" style="-fx-background-color: rgba(0, 255, 136, 0.12); -fx-text-fill: #00ff88; -fx-font-weight: bold; -fx-background-radius: 5; -fx-border-color: rgba(0, 255, 136, 0.3); -fx-border-width: 1; -fx-cursor: hand;" text="Curar Todos" />
            </children>
         </HBox>
      </VBox>
   </top>

   <!-- ========== CONTEUDO CENTRAL ========== -->
   <center>
      <SplitPane dividerPositions="0.40" style="-fx-background-color: transparent;">

          <!-- ===== COLUNA ESQUERDA: Seletor de Combatentes ===== -->
          <VBox spacing="8.0" styleClass="editor-sidebar" style="-fx-min-width: 260px; -fx-pref-width: 290px; -fx-max-width: 330px;">
             <Label styleClass="header-label" text="Combatentes" maxWidth="Infinity"/>
             <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;" hbarPolicy="NEVER">
                <content>
                   <VBox fx:id="combatListContainer" spacing="8.0" style="-fx-background-color: transparent;" />
                </content>
             </ScrollPane>
          </VBox>

         <!-- ===== COLUNA DIREITA: Editor de Personagem ===== -->
         <VBox spacing="0" styleClass="editor-background">
            <!-- Cabecalho com nome do personagem -->
            <HBox styleClass="character-header" spacing="15.0" alignment="CENTER_LEFT">
                <VBox spacing="4" alignment="CENTER_LEFT">
                    <Label fx:id="lblNomeSelecionado" styleClass="label-name" text="Selecione um Personagem" />
                    <Label fx:id="lblInfoSelecionado" styleClass="label-class" text="" />
                </VBox>
            </HBox>

            <TabPane fx:id="tabPaneDetalhes" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" styleClass="editor-tab-pane">

               <!-- ==================== ABA 1: PRINCIPAL ==================== -->
               <Tab text="Principal" styleClass="editor-tab">
                  <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                  <VBox spacing="12.0" style="-fx-padding: 12;" styleClass="editor-background">

                     <!-- Secao: Status Vital -->
                     <VBox spacing="8.0" styleClass="bento-card">
                        <Label styleClass="header-label" text="Status Vital" />
                        <GridPane hgap="8.0" vgap="8.0">
                            <columnConstraints>
                               <ColumnConstraints hgrow="SOMETIMES" percentWidth="25" />
                               <ColumnConstraints hgrow="SOMETIMES" percentWidth="45" />
                               <ColumnConstraints hgrow="SOMETIMES" percentWidth="30" />
                            </columnConstraints>

                            <Label text="Vida:" style="-fx-text-fill: #66ff66; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                            <TextField fx:id="inputVida" promptText="HP" styleClass="editor-search-field" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                            <Label fx:id="lblVidaMax" style="-fx-text-fill: #888;" text="/ ???" GridPane.rowIndex="0" GridPane.columnIndex="2" />

                            <Label text="Escudo (N/S/D):" style="-fx-text-fill: #66bbff; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                            <HBox spacing="6.0" GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="2">
                                <TextField fx:id="inputEscudoNormal" promptText="Normal" styleClass="editor-search-field" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="inputEscudoSangue" promptText="Sangue" styleClass="editor-search-field" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="inputEscudoDivino" promptText="Divino" styleClass="editor-search-field" HBox.hgrow="ALWAYS" />
                            </HBox>

                            <Label text="Mana:" style="-fx-text-fill: #bb88ff; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                            <TextField fx:id="inputMana" promptText="MP" styleClass="editor-search-field" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                            <Label fx:id="lblManaMax" style="-fx-text-fill: #888;" text="/ ???" GridPane.rowIndex="2" GridPane.columnIndex="2" />

                            <Label text="TU:" style="-fx-text-fill: #ffcc44; -fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                            <TextField fx:id="inputTU" promptText="Turn Units" styleClass="editor-search-field" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                        </GridPane>

                        <HBox alignment="CENTER" spacing="8.0" style="-fx-padding: 5 0 0 0;">
                            <Button onAction="#onAplicarStatusClick" style="-fx-background-color: rgba(0, 255, 136, 0.15); -fx-text-fill: #00ff88; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-color: rgba(0, 255, 136, 0.4); -fx-border-width: 1.5; -fx-font-size: 13px; -fx-cursor: hand;" text="APLICAR STATUS" maxWidth="Infinity" HBox.hgrow="ALWAYS" prefHeight="35"/>
                        </HBox>

                        <Separator style="-fx-padding: 3 0;" />

                        <HBox alignment="CENTER" spacing="8.0">
                            <Button onAction="#onReviverClick" style="-fx-background-color: rgba(0, 255, 136, 0.08); -fx-text-fill: #00ff88; -fx-background-radius: 5; -fx-border-color: rgba(0, 255, 136, 0.25); -fx-border-width: 1; -fx-cursor: hand; -fx-font-size: 11px;" text="Reviver" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Button onAction="#onDescansarClick" style="-fx-background-color: rgba(0, 240, 255, 0.08); -fx-text-fill: #00f0ff; -fx-background-radius: 5; -fx-border-color: rgba(0, 240, 255, 0.25); -fx-border-width: 1; -fx-cursor: hand; -fx-font-size: 11px;" text="Descansar" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Button onAction="#onMatarClick" style="-fx-background-color: rgba(255, 75, 75, 0.08); -fx-text-fill: #ff4b4b; -fx-background-radius: 5; -fx-border-color: rgba(255, 75, 75, 0.25); -fx-border-width: 1; -fx-cursor: hand; -fx-font-size: 11px;" text="Kill" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        </HBox>

                        <Separator style="-fx-padding: 3 0;" />
                        <Label styleClass="header-label" text="Ações Rápidas (Marionete/Facção)" style="-fx-font-size: 12px; -fx-padding: 0 0 4 0;" />
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <TextField fx:id="inputValorRapido" promptText="Valor" styleClass="editor-search-field" prefWidth="80.0" />
                            <Button onAction="#onCuraRapidaClick" style="-fx-background-color: rgba(0, 255, 136, 0.12); -fx-text-fill: #00ff88; -fx-background-radius: 5; -fx-border-color: rgba(0, 255, 136, 0.3); -fx-border-width: 1; -fx-cursor: hand; -fx-font-size: 11px;" text="Cura (Ignora)" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Button onAction="#onDanoRapidoClick" style="-fx-background-color: rgba(255, 75, 75, 0.12); -fx-text-fill: #ff4b4b; -fx-background-radius: 5; -fx-border-color: rgba(255, 75, 75, 0.3); -fx-border-width: 1; -fx-cursor: hand; -fx-font-size: 11px;" text="Dano Oposto" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        </HBox>
                     </VBox>

                     <!-- Secao: Progresso e Nivel -->
                      <VBox spacing="8.0" styleClass="bento-card">
                         <Label styleClass="header-label" text="Progresso e Nível" />
                         <GridPane hgap="8.0" vgap="8.0">
                            <columnConstraints>
                               <ColumnConstraints percentWidth="20" />
                               <ColumnConstraints percentWidth="30" />
                               <ColumnConstraints percentWidth="25" />
                               <ColumnConstraints percentWidth="25" />
                            </columnConstraints>
                            
                            <!-- Row 0: XP -->
                            <Label text="XP:" style="-fx-text-fill: #cc88ff; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                            <TextField fx:id="inputXPManual" promptText="Qtd" styleClass="editor-search-field" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                            <Button text="+ XP" onAction="#onAdicionarXPClick" style="-fx-background-color: rgba(204, 136, 255, 0.15); -fx-text-fill: #cc88ff; -fx-background-radius: 5; -fx-border-color: rgba(204, 136, 255, 0.3); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                            <Button text="- XP" onAction="#onSubtrairXPClick" style="-fx-background-color: rgba(204, 136, 255, 0.15); -fx-text-fill: #a060cc; -fx-background-radius: 5; -fx-border-color: rgba(204, 136, 255, 0.2); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="3" />

                            <!-- Row 1: Grau -->
                            <Label text="Grau:" style="-fx-text-fill: #00ffcc; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                            <TextField fx:id="inputGrau" promptText="Grau" styleClass="editor-search-field" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                            <Button text="Set Grau" onAction="#onSetGrauClick" style="-fx-background-color: rgba(0, 255, 204, 0.15); -fx-text-fill: #00ffcc; -fx-background-radius: 5; -fx-border-color: rgba(0, 255, 204, 0.3); -fx-border-width: 1; -fx-cursor: hand;" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="2" GridPane.columnSpan="2" />

                            <!-- Row 2: Pontos -->
                            <Label text="Pontos:" style="-fx-text-fill: #ff9900; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                            <TextField fx:id="inputPontos" promptText="Pts" styleClass="editor-search-field" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                            <Button text="+" onAction="#onAddPontosClick" style="-fx-background-color: rgba(255, 153, 0, 0.15); -fx-text-fill: #ff9900; -fx-background-radius: 5; -fx-border-color: rgba(255, 153, 0, 0.3); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" maxWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="2" />
                            <Button text="-" onAction="#onRemovePontosClick" style="-fx-background-color: rgba(255, 153, 0, 0.15); -fx-text-fill: #cc7700; -fx-background-radius: 5; -fx-border-color: rgba(255, 153, 0, 0.2); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" maxWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="3" />
                         </GridPane>
                         <Label fx:id="lblXPInfo" style="-fx-text-fill: #aaa; -fx-font-size: 11px;" text="" />
                      </VBox>

                     <!-- Secao: Controle de Sessao -->
                     <VBox spacing="8.0" styleClass="bento-card">
                        <Label styleClass="header-label" text="Controle de Sessão" />
                        <CheckBox fx:id="checkAusente" onAction="#onCheckAusenteChange" text="Jogador Ausente (Ocultar)" style="-fx-text-fill: #aaa;" />
                        <CheckBox fx:id="checkProtagonista" onAction="#onCheckProtagonistaChange" text="Modo Protagonista (? HP, Imune)" style="-fx-text-fill: #ffcc00;" />
                        <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-padding: 4 0 0 0;">
                            <Label text="Facção:" style="-fx-text-fill: #aaa;" />
                            <ComboBox fx:id="comboFaccao" onAction="#onComboFaccaoChange" styleClass="editor-search-field" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        </HBox>
                     </VBox>

                     <!-- Secao: Financas -->
                     <VBox spacing="8.0" styleClass="bento-card">
                        <Label styleClass="header-label" text="Finanças" />
                        <GridPane hgap="6.0" vgap="6.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="15" />
                                <ColumnConstraints percentWidth="35" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                            </columnConstraints>

                            <Label text="Ouro:" style="-fx-text-fill: #ffd700; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="inputOuro" text="0" styleClass="editor-search-field" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <Button text="+" onAction="#onAddOuroClick" style="-fx-background-color: rgba(255, 215, 0, 0.12); -fx-text-fill: #ffd700; -fx-background-radius: 5; -fx-border-color: rgba(255, 215, 0, 0.3); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="2" maxWidth="Infinity"/>
                            <Button text="-" onAction="#onRemoveOuroClick" style="-fx-background-color: rgba(170, 136, 0, 0.12); -fx-text-fill: #aa8800; -fx-background-radius: 5; -fx-border-color: rgba(170, 136, 0, 0.25); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="3" maxWidth="Infinity"/>

                            <Label text="Prata:" style="-fx-text-fill: #c0c0c0; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="inputPrata" text="0" styleClass="editor-search-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            <Button text="+" onAction="#onAddPrataClick" style="-fx-background-color: rgba(192, 192, 192, 0.12); -fx-text-fill: #c0c0c0; -fx-background-radius: 5; -fx-border-color: rgba(192, 192, 192, 0.3); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="2" maxWidth="Infinity"/>
                            <Button text="-" onAction="#onRemovePrataClick" style="-fx-background-color: rgba(128, 128, 128, 0.12); -fx-text-fill: #808080; -fx-background-radius: 5; -fx-border-color: rgba(128, 128, 128, 0.25); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="3" maxWidth="Infinity"/>

                            <Label text="Bronze:" style="-fx-text-fill: #cd7f32; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="inputBronze" text="0" styleClass="editor-search-field" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            <Button text="+" onAction="#onAddBronzeClick" style="-fx-background-color: rgba(205, 127, 50, 0.12); -fx-text-fill: #cd7f32; -fx-background-radius: 5; -fx-border-color: rgba(205, 127, 50, 0.3); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="2" maxWidth="Infinity"/>
                            <Button text="-" onAction="#onRemoveBronzeClick" style="-fx-background-color: rgba(138, 85, 34, 0.12); -fx-text-fill: #8a5522; -fx-background-radius: 5; -fx-border-color: rgba(138, 85, 34, 0.25); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="3" maxWidth="Infinity"/>
                        </GridPane>
                        
                        <HBox spacing="8.0" alignment="CENTER_LEFT" style="-fx-padding: 4 0 0 0;">
                            <Label text="Alterar Qtd:" style="-fx-text-fill: #aaa; -fx-font-size: 11px;" />
                            <TextField fx:id="inputQtdAlterarMoedas" text="1" styleClass="editor-search-field" prefWidth="60.0"/>
                        </HBox>
                        
                        <Label fx:id="lblTotalMoedas" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="Total: 0 bronze" />
                     </VBox>

                  </VBox>
                  </ScrollPane>
               </Tab>

               <!-- ==================== ABA 2: INVENTARIO ==================== -->
               <Tab text="Inventário" styleClass="editor-tab">
                  <VBox spacing="10.0" style="-fx-padding: 12;" styleClass="editor-background">

                     <!-- Sessao: Adicionar Item -->
                     <VBox spacing="8.0" styleClass="bento-card" VBox.vgrow="ALWAYS">
                        <Label styleClass="header-label" text="Adicionar Item" />

                        <!-- Filtros -->
                        <HBox spacing="6" alignment="CENTER_LEFT">
                           <TextField fx:id="inputBuscaItem" promptText="Buscar item..." styleClass="editor-search-field" HBox.hgrow="ALWAYS" />
                           <ComboBox fx:id="comboFiltroTipoItem" prefWidth="120" promptText="Tipo..." style="-fx-font-size: 11px;" />
                           <ComboBox fx:id="comboFiltroRaridade" prefWidth="120" promptText="Raridade..." style="-fx-font-size: 11px;" />
                        </HBox>

                        <ListView fx:id="listaItensFiltrados" VBox.vgrow="ALWAYS" styleClass="editor-list-view" style="-fx-max-height: 160px;"/>
                        <HBox alignment="CENTER_LEFT" spacing="6.0">
                            <Label text="Qtd:" style="-fx-text-fill: #aaa;" />
                            <TextField fx:id="inputQtdItem" prefWidth="50.0" text="1" styleClass="editor-search-field" />
                            <Button maxWidth="Infinity" onAction="#onAdicionarItemClick" text="Adicionar ao Inventário" HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(0, 255, 136, 0.12); -fx-text-fill: #00ff88; -fx-background-radius: 5; -fx-border-color: rgba(0, 255, 136, 0.3); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" />
                        </HBox>
                     </VBox>

                     <!-- Sessao: Inventario Atual -->
                     <VBox spacing="8.0" styleClass="bento-card" VBox.vgrow="ALWAYS">
                        <Label styleClass="header-label" text="Inventário Atual" />
                        <ListView fx:id="listaInventarioAtual" VBox.vgrow="ALWAYS" styleClass="editor-list-view" />
                        <HBox spacing="6">
                           <Button maxWidth="Infinity" onAction="#onRemoverItemClick" text="Remover Qtd Selecionada" style="-fx-background-color: rgba(255, 75, 75, 0.12); -fx-text-fill: #ff4b4b; -fx-background-radius: 5; -fx-border-color: rgba(255, 75, 75, 0.3); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" HBox.hgrow="ALWAYS" />
                        </HBox>
                     </VBox>
                  </VBox>
               </Tab>

               <!-- ==================== ABA 3: EFEITOS ==================== -->
               <Tab text="Efeitos" styleClass="editor-tab">
                  <VBox spacing="10.0" style="-fx-padding: 12;" styleClass="editor-background">

                     <!-- Sessao: Aplicar Novo Efeito -->
                     <VBox spacing="8.0" styleClass="bento-card">
                        <Label styleClass="header-label" text="Aplicar Novo Efeito" />

                        <HBox spacing="8" alignment="CENTER_LEFT">
                           <Label text="Efeito:" style="-fx-text-fill: #aaa; -fx-min-width: 55;" />
                           <ComboBox fx:id="comboPresetEfeito" maxWidth="Infinity" promptText="Selecionar efeito..." HBox.hgrow="ALWAYS" />
                        </HBox>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                           <Label text="Duração:" style="-fx-text-fill: #aaa; -fx-min-width: 55;" />
                           <TextField fx:id="inputDuracaoEfeito" text="300" styleClass="editor-search-field" prefWidth="90" />
                           <Label text="TU" style="-fx-text-fill: #666;" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label text="Valor:" style="-fx-text-fill: #aaa;" />
                           <TextField fx:id="inputValorEfeito" promptText="Dano/Valor" text="0" styleClass="editor-search-field" prefWidth="80" />
                        </HBox>

                        <!-- Customizacoes opcionais do efeito -->
                        <HBox spacing="8" alignment="CENTER_LEFT">
                           <Label text="Stacks:" style="-fx-text-fill: #aaa; -fx-min-width: 55;" />
                           <TextField fx:id="inputStacksEfeito" text="0" styleClass="editor-search-field" prefWidth="60" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label text="Intervalo:" style="-fx-text-fill: #aaa;" />
                           <TextField fx:id="inputIntervaloEfeito" promptText="Tick TU" text="" styleClass="editor-search-field" prefWidth="70" />
                        </HBox>

                        <Button maxWidth="Infinity" onAction="#onAdicionarEfeitoManualClick" style="-fx-background-color: rgba(204, 136, 255, 0.15); -fx-text-fill: #cc88ff; -fx-font-weight: bold; -fx-background-radius: 5; -fx-border-color: rgba(204, 136, 255, 0.35); -fx-border-width: 1.5; -fx-font-size: 13px; -fx-cursor: hand;" text="Aplicar Efeito" prefHeight="32" />
                     </VBox>

                     <!-- Sessao: Efeitos Ativos do Personagem -->
                     <VBox spacing="8.0" styleClass="bento-card" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                           <Label styleClass="header-label" text="Efeitos Ativos" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                           <Button onAction="#onLimparEfeitosClick" style="-fx-background-color: rgba(255, 75, 75, 0.12); -fx-text-fill: #ff4b4b; -fx-background-radius: 5; -fx-border-color: rgba(255, 75, 75, 0.25); -fx-border-width: 1; -fx-font-size: 10px; -fx-cursor: hand;" text="Limpar Todos" />
                        </HBox>
                        <ListView fx:id="listaEfeitosAtivos" VBox.vgrow="ALWAYS" styleClass="editor-list-view" />

                        <!-- Editor de Efeito Selecionado -->
                        <VBox fx:id="painelEditorEfeito" spacing="6" style="-fx-background-color: rgba(22, 22, 38, 0.8); -fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #e94560; -fx-border-radius: 6; -fx-border-width: 1;" managed="false" visible="false">
                           <Label fx:id="lblNomeEfeitoEditando" style="-fx-font-weight: bold; -fx-text-fill: #cc88ff; -fx-font-size: 12px;" text="Editando: ---" />
                           <HBox spacing="6" alignment="CENTER_LEFT">
                              <Label text="Dur. Rest.:" style="-fx-text-fill: #aaa; -fx-font-size: 11px;" />
                              <TextField fx:id="inputEditDuracao" prefWidth="70" styleClass="editor-search-field" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label text="Dano/Tick:" style="-fx-text-fill: #aaa; -fx-font-size: 11px;" />
                              <TextField fx:id="inputEditDanoPorTick" prefWidth="60" styleClass="editor-search-field" />
                           </HBox>
                           <HBox spacing="6" alignment="CENTER_LEFT">
                              <Label text="Intervalo:" style="-fx-text-fill: #aaa; -fx-font-size: 11px;" />
                              <TextField fx:id="inputEditIntervalo" prefWidth="70" styleClass="editor-search-field" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label text="Stacks:" style="-fx-text-fill: #aaa; -fx-font-size: 11px;" />
                              <TextField fx:id="inputEditStacks" prefWidth="60" styleClass="editor-search-field" />
                           </HBox>
                           <HBox spacing="6" alignment="CENTER_LEFT">
                              <Label text="Mod. chave:" style="-fx-text-fill: #aaa; -fx-font-size: 11px;" />
                              <TextField fx:id="inputEditModChave" prefWidth="100" promptText="ex: DANO_BONUS" styleClass="editor-search-field" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label text="Valor:" style="-fx-text-fill: #aaa; -fx-font-size: 11px;" />
                              <TextField fx:id="inputEditModValor" prefWidth="60" styleClass="editor-search-field" />
                           </HBox>
                           <HBox spacing="6" alignment="CENTER">
                              <Button onAction="#onSalvarEdicaoEfeitoClick" text="Salvar Alterações" style="-fx-background-color: rgba(0, 255, 136, 0.12); -fx-text-fill: #00ff88; -fx-background-radius: 5; -fx-border-color: rgba(0, 255, 136, 0.3); -fx-border-width: 1; -fx-font-size: 11px; -fx-cursor: hand;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                              <Button onAction="#onRemoverEfeitoClick" text="Remover Efeito" style="-fx-background-color: rgba(255, 75, 75, 0.12); -fx-text-fill: #ff4b4b; -fx-background-radius: 5; -fx-border-color: rgba(255, 75, 75, 0.3); -fx-border-width: 1; -fx-font-size: 11px; -fx-cursor: hand;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                           </HBox>
                        </VBox>
                     </VBox>
                  </VBox>
               </Tab>

               <!-- ==================== ABA 4: FILA DE TURNOS ==================== -->
               <Tab text="Fila de Turnos" styleClass="editor-tab">
                  <VBox spacing="10.0" style="-fx-padding: 12;" styleClass="editor-background">
                     <VBox spacing="8.0" styleClass="bento-card" VBox.vgrow="ALWAYS">
                        <Label styleClass="header-label" text="Ordem de Turnos" />
                        <ListView fx:id="listaTurnos" VBox.vgrow="ALWAYS" styleClass="editor-list-view" />
                        <HBox spacing="10.0" alignment="CENTER">
                           <Button text="▲ Subir Vez" onAction="#onSubirTurnoClick" style="-fx-background-color: rgba(0, 240, 255, 0.12); -fx-text-fill: #00f0ff; -fx-background-radius: 5; -fx-border-color: rgba(0, 240, 255, 0.3); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                           <Button text="▼ Descer Vez" onAction="#onDescerTurnoClick" style="-fx-background-color: rgba(0, 240, 255, 0.12); -fx-text-fill: #00f0ff; -fx-background-radius: 5; -fx-border-color: rgba(0, 240, 255, 0.3); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        </HBox>
                     </VBox>
                  </VBox>
               </Tab>

               <!-- ==================== ABA 5: CONTRATOS DE VIDA ==================== -->
               <Tab text="Contratos" styleClass="editor-tab">
                  <VBox spacing="10.0" style="-fx-padding: 12;" styleClass="editor-background">
                     <HBox spacing="10.0" VBox.vgrow="ALWAYS">
                        <!-- Left Side: List of active contracts -->
                        <VBox spacing="8.0" styleClass="bento-card" HBox.hgrow="ALWAYS" prefWidth="300.0">
                           <Label styleClass="header-label" text="Contratos Ativos" />
                           <ListView fx:id="listaContratos" VBox.vgrow="ALWAYS" styleClass="editor-list-view" />
                           <Button text="Remover Contrato Selecionado" onAction="#onRemoverContratoClick" style="-fx-background-color: rgba(255, 75, 75, 0.12); -fx-text-fill: #ff4b4b; -fx-background-radius: 5; -fx-border-color: rgba(255, 75, 75, 0.3); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" maxWidth="Infinity" />
                        </VBox>

                        <!-- Right Side: Add new contract -->
                        <VBox spacing="8.0" styleClass="bento-card" HBox.hgrow="ALWAYS" prefWidth="250.0">
                           <Label styleClass="header-label" text="Novo Contrato" />
                           <GridPane hgap="8.0" vgap="8.0">
                              <columnConstraints>
                                 <ColumnConstraints percentWidth="35" />
                                 <ColumnConstraints percentWidth="65" />
                              </columnConstraints>
                              
                              <Label text="Fonte:" style="-fx-text-fill: #aaa;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                              <ComboBox fx:id="comboFonteContrato" maxWidth="Infinity" promptText="Selecione..." GridPane.rowIndex="0" GridPane.columnIndex="1" />

                              <Label text="Valor:" style="-fx-text-fill: #aaa;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                              <TextField fx:id="inputValorContrato" promptText="HP" styleClass="editor-search-field" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                              <Label text="Duração:" style="-fx-text-fill: #aaa;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                              <TextField fx:id="inputDuracaoContrato" text="-1" promptText="TU" styleClass="editor-search-field" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                           </GridPane>
                           
                           <CheckBox fx:id="checkPersisteContrato" text="Persiste Após Combate" style="-fx-text-fill: #aaa; -fx-font-size: 11px; -fx-padding: 4 0;" selected="true" />
                           
                           <Region VBox.vgrow="ALWAYS" />
                           <Button text="Adicionar Contrato" onAction="#onAdicionarContratoClick" style="-fx-background-color: rgba(0, 255, 136, 0.12); -fx-text-fill: #00ff88; -fx-background-radius: 5; -fx-border-color: rgba(0, 255, 136, 0.3); -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" maxWidth="Infinity" />
                        </VBox>
                     </HBox>
                  </VBox>
               </Tab>

               <!-- ==================== ABA 6: SISTEMA ==================== -->
               <Tab text="Sistema" styleClass="editor-tab">
                  <VBox spacing="15.0" style="-fx-padding: 20;" styleClass="editor-background" alignment="TOP_CENTER">
                     <VBox spacing="12" styleClass="bento-card" maxWidth="400.0">
                        <Label styleClass="header-label" text="Persistência de Sessão" maxWidth="Infinity" />
                        <Button onAction="#onSalvarTudoClick" style="-fx-background-color: rgba(0, 240, 255, 0.15); -fx-text-fill: #00f0ff; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 5; -fx-border-color: rgba(0, 240, 255, 0.45); -fx-border-width: 1.5; -fx-cursor: hand;" text="SALVAR ESTADO ATUAL" maxWidth="Infinity" prefHeight="45"/>
                        <Label text="Salva vida, mana, posição e inventário de todos." style="-fx-text-fill: #8c8ba5; -fx-font-size: 11px;" />
                        <Separator style="-fx-padding: 5 0;" />
                        <Button onAction="#onCarregarTudoClick" style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-text-fill: #ccc; -fx-background-radius: 5; -fx-border-color: rgba(255, 255, 255, 0.15); -fx-border-width: 1; -fx-cursor: hand;" text="Carregar Último Save" maxWidth="Infinity" prefHeight="35" />
                        <Label text="Reverte para o último estado salvo no disco." style="-fx-text-fill: #666; -fx-font-size: 11px;" />
                     </VBox>
                  </VBox>
               </Tab>

            </TabPane>
         </VBox>
      </SplitPane>
   </center>
</BorderPane>
