<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="root" stylesheets="@style.css" minWidth="0.0" minHeight="0.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.dantesrpg.controller.MapController">

    <center>
        <StackPane pickOnBounds="false" minWidth="0.0" minHeight="0.0">
            <StackPane fx:id="mapViewport" style="-fx-background-color: #222222;" minWidth="0.0" minHeight="0.0">
                <StackPane fx:id="mapContent" alignment="TOP_LEFT" maxWidth="-Infinity" maxHeight="-Infinity">
                    <GridPane fx:id="mapGrid" style="-fx-background-color: #222222;">
                    </GridPane>
                    <Canvas fx:id="aoeCanvas" mouseTransparent="true" />
                </StackPane>
            </StackPane>
            <HBox fx:id="floatingToggleBox" alignment="CENTER" spacing="4.0" visible="false" managed="false" StackPane.alignment="BOTTOM_CENTER" styleClass="floating-mode-capsule" pickOnBounds="false">
                <StackPane.margin>
                    <Insets bottom="20.0" />
                </StackPane.margin>
                <children>
                    <ToggleButton fx:id="toggleMover" text="Movimentar">
                        <toggleGroup>
                            <ToggleGroup fx:id="selectionToggleGroup" />
                        </toggleGroup>
                    </ToggleButton>
                    <ToggleButton fx:id="toggleMirar" text="Mirar" toggleGroup="$selectionToggleGroup" />
                </children>
            </HBox>
        </StackPane>
    </center>

</BorderPane>

