<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.dantesrpg.controller.LojaController">
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
   </padding>
   
   <top>
      <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-border-color: yellow; -fx-padding: 10;">
         <children>
            <Label text="LOJA" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: yellow;"/>
            <ComboBox fx:id="comboSelecaoLoja" prefWidth="200.0" promptText="Selecione a Loja..."/>
            <Label text="Comprador:" style="-fx-text-fill: white; -fx-padding: 0 0 0 30;"/>
            <ComboBox fx:id="playerSelectorComboBox" onAction="#onPlayerSelected" prefWidth="150.0"/>
            <HBox alignment="CENTER_LEFT" spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Moedas:" style="-fx-text-fill: white;"/>
                  <Label fx:id="labelMoedasOuro" text="0 Ouro" style="-fx-text-fill: gold;"/>
                  <Label fx:id="labelMoedasPrata" text="0 Prata" style="-fx-text-fill: silver;"/>
                  <Label fx:id="labelMoedasBronze" text="0 Bronze" style="-fx-text-fill: #CD7F32;"/>
               </children>
            </HBox>
         </children>
      </HBox>
   </top>
   
   <center>
    <HBox spacing="10.0" style="-fx-padding: 10;">
        
        <VBox HBox.hgrow="ALWAYS" prefWidth="400.0" spacing="5.0">
            <Label text="Itens à Venda:" styleClass="header-label"/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                <VBox fx:id="itensVendaContainer" spacing="5.0" />
            </ScrollPane>
        </VBox>
        
        <VBox styleClass="editor-column" HBox.hgrow="NEVER" prefWidth="300.0" spacing="5.0">
            <Label fx:id="previewNome" text="Selecione um Item" styleClass="header-label" />
            <Label fx:id="previewDescricao" text="A descrição do item aparecerá aqui." wrapText="true" />
            
            <VBox fx:id="previewStatsPane" style="-fx-padding-top: 15;" spacing="3.0" />
        </VBox>
        
    </HBox>
</center>
   
   <right>
      <VBox spacing="10.0" prefWidth="300.0">
         <children>
            <Label text="Seu Inventário:" style="-fx-font-size: 18px; -fx-text-fill: white;"/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="inventarioJogadorContainer" spacing="5.0" />
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </right>
   </BorderPane>