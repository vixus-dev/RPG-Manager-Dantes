<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #222; -fx-border-color: #555; -fx-border-width: 2;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.dantesrpg.controller.AttributeTestPromptController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label text="TESTE DE RESISTÊNCIA" textFill="#e74c3c">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label fx:id="lblContexto" text="O limite do corpo humano foi atingido." textFill="white" wrapText="true" textAlignment="CENTER"/>
      
      <HBox alignment="CENTER" spacing="10">
          <Label text="Dificuldade (NA):" textFill="#aaaaaa"/>
          <Label fx:id="lblDificuldade" text="15 (Extrema)" textFill="yellow">
             <font>
                <Font name="System Bold" size="14.0" />
             </font>
          </Label>
      </HBox>

      <Label text="Role 1d20 + ENDURANCE:" textFill="white" />
      
      <TextField fx:id="inputRolagem" alignment="CENTER" promptText="Resultado Final" style="-fx-background-color: #333; -fx-text-fill: white; -fx-border-color: #777;" maxWidth="150.0" />
      
      <Button fx:id="btnConfirmar" defaultButton="true" mnemonicParsing="false" onAction="#onConfirmarClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="CONFIRMAR DESTINO" />
   </children>
</VBox>